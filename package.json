{
  "name": "scaffinity",
  "version": "1.1.0",
  "description": "Generate, export, and share project structures as portable JSON blueprints",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "scaffinity": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "scaffinity",
    "cli",
    "boilerplate",
    "project-structure",
    "generator",
    "typescript",
    "blueprint"
  ],
  "author": "Deviprasad Rai <dpraidola@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.5",
    "ora": "^9.4.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.0.1",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
